{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci && bundle install",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "_site",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://specifys-ai-backend.onrender.com/sitemap.xml"
    }
  ],
  "headers": [
    {
      "source": "/assets/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
