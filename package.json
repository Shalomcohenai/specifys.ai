{
  "name": "specifys-ai",
  "version": "1.2.4",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "echo \"This is a frontend package. Use 'cd backend && npm start' to run the backend server.\" && exit 1",
    "dev": "cd backend/server && npm run dev",
    "dev:site": "bundle exec jekyll serve",
    "build:vite": "vite build",
    "dev:vite": "vite",
    "build:all": "npm run build:vite && bundle exec jekyll build",
    "build:css": "sass assets/css/main.scss assets/css/main-compiled.css --style=expanded",
    "build:css:min": "npx sass assets/css/main.scss assets/css/main-compiled.css --style=compressed --no-source-map",
    "watch:css": "sass --watch assets/css/main.scss:assets/css/main-compiled.css",
    "check:env": "node scripts/check-env.mjs",
    "check:ports": "npm run check:env",
    "test:e2e": "playwright test",
    "build:packages": "npm run build --workspaces --if-present",
    "build:monorepo": "npm run build:packages && npm run build:css && npm run build:vite"
  },
  "keywords": [
    "specifys",
    "ai",
    "app-planning",
    "vibe-coding"
  ],
  "author": "Specifys.ai",
  "license": "ISC",
  "description": "Clean Specifys.ai website - ready for user system integration",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^13.5.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-legacy": "^5.4.0",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "sass": "^1.94.2",
    "vite": "^5.4.8",
    "vite-plugin-static-copy": "^1.0.4"
  }
}
