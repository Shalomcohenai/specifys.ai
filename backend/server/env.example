# Server Configuration
PORT=3001

# OpenAI Configuration (for OpenAI Storage Integration)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Enable OpenAI Storage upload (set to 'true' to enable)
ENABLE_OPENAI_STORAGE=false

# Note: API_KEY is no longer used - all spec generation goes through Cloudflare Worker
# OpenAI API key is only needed for chat/storage features (OPENAI_API_KEY above)

# Automation Configuration
# Enable/disable automation features (set to 'false' to disable)
AUTOMATION_ENABLED=true
TOOLS_AUTOMATION_ENABLED=true
ARTICLES_AUTOMATION_ENABLED=true
# Note: OPENAI_API_KEY (above) is required for automation features

# Credits Sync Configuration
# Enable/disable daily credits sync (set to 'false' to disable)
CREDITS_SYNC_ENABLED=true
# Run in dry-run mode (no changes made, only reports)
CREDITS_SYNC_DRY_RUN=false
# Number of users to process in each batch
CREDITS_SYNC_BATCH_SIZE=50
# Rate limiting delay between API calls (ms)
CREDITS_SYNC_RATE_LIMIT_DELAY=100
# Note: LEMON_SQUEEZY_API_KEY (below) is required for credits sync

# Email Configuration (for Nodemailer)
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
FEEDBACK_EMAIL=feedback@yourdomain.com

# Google Sheets Configuration
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Alternative: Direct Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_FILE=path/to/credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Optional: Database Configuration
DATABASE_URL=your_database_connection_string

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_KEY_FILE=../firebase-service-account.json
FIREBASE_PROJECT_ID=specify-ai
FIREBASE_STORAGE_BUCKET=specify-ai.appspot.com

# MCP – Per-user (production): no env vars needed. Users get keys via Profile → MCP API Key or POST /api/users/me/mcp-api-key.
# Optional (single-user / dev only): set both to one fixed user.
# MCP_API_KEY=your_secret_key
# MCP_API_USER_ID=firebase_uid_of_the_user